tabla_dep_sexo <- base_compuestas %>%
count(sexo, clasificacion_depresion) %>%
pivot_wider(
names_from = clasificacion_depresion,
values_from = n,
values_fill = 0
) %>%
mutate(
Total = Alta + Baja,
`% Alta` = round((Alta / Total) * 100, 1)
)
